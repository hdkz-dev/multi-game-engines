{
  "name": "@multi-game-engines/adapter-kingsrow",
  "version": "1.0.1",
  "description": "Checkers (English Draughts) adapter powered by rapid-draughts (replaces proprietary KingsRow)",
  "type": "module",
  "license": "MIT",
  "author": "hdkz-dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hdkz-dev/multi-game-engines.git",
    "directory": "packages/adapter-kingsrow"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "checkers",
    "engine",
    "kingsrow",
    "wasm",
    "multi-game-engines"
  ],
  "dependencies": {
    "@multi-game-engines/i18n-common": "workspace:*",
    "rapid-draughts": "^1.0.6"
  },
  "peerDependencies": {
    "@multi-game-engines/core": "workspace:*"
  },
  "devDependencies": {
    "@multi-game-engines/domain-checkers": "workspace:*",
    "eslint": "^10.4.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "scripts": {
    "build": "tsup src/index.ts --external @multi-game-engines/* --format esm && tsc --emitDeclarationOnly --composite false --declaration --outDir dist",
    "dev": "tsup src/index.ts --external @multi-game-engines/* --format esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "bugs": {
    "url": "https://github.com/hdkz-dev/multi-game-engines/issues"
  },
  "homepage": "https://github.com/hdkz-dev/multi-game-engines#readme"
}
