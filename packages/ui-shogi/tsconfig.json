{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    // Keep the incremental build cache out of dist so it is not published (composite: true in tsconfig.base.json otherwise emits it into outDir).
    "tsBuildInfoFile": "./node_modules/.cache/tsconfig.tsbuildinfo",
    "jsx": "react-jsx",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "paths": {
      "@multi-game-engines/ui-shogi-elements": [
        "../ui-shogi-elements/src/index.ts"
      ]
    }
  },
  "include": ["src/**/*", ".storybook/**/*"],
  "exclude": ["node_modules", "dist"]
}
