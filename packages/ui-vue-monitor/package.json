{
  "name": "@multi-game-engines/ui-vue-monitor",
  "version": "0.1.0",
  "description": "Engine monitoring and management components for Vue 3",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "vite build && vue-tsc --emitDeclarationOnly --declaration --outDir dist --composite false",
    "dev": "vite build --watch",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "vue-tsc --noEmit"
  },
  "license": "MIT",
  "sideEffects": [
    "*.css",
    "*.vue"
  ],
  "peerDependencies": {
    "vue": ">=3.3.0"
  },
  "dependencies": {
    "@multi-game-engines/core": "workspace:*",
    "@multi-game-engines/i18n-common": "workspace:*",
    "@multi-game-engines/ui-core": "workspace:*",
    "@multi-game-engines/ui-vue-core": "workspace:*",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^1.0.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@storybook/vue3": "10.3.4",
    "@storybook/vue3-vite": "10.3.4",
    "@types/node": "^25.5.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.8.9",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.2",
    "vue": "3.5.32",
    "vue-tsc": "^3.2.6"
  },
  "author": "hdkz-dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hdkz-dev/multi-game-engines.git",
    "directory": "packages/ui-vue-monitor"
  },
  "bugs": {
    "url": "https://github.com/hdkz-dev/multi-game-engines/issues"
  },
  "homepage": "https://github.com/hdkz-dev/multi-game-engines#readme",
  "engines": {
    "node": ">=24.0.0"
  }
}
