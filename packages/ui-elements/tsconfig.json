{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    // Keep the incremental build cache out of dist so it is not published (composite: true in tsconfig.base.json otherwise emits it into outDir).
    "tsBuildInfoFile": "./node_modules/.cache/tsconfig.tsbuildinfo"
  },
  "include": ["src/**/*"],
  "exclude": [".storybook/**/*"]
}
