{
  "name": "@multi-game-engines/ui-elements",
  "version": "0.1.6",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "description": "Framework-agnostic Web Components for multi-game engines",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --external @multi-game-engines/* --format esm && tsc -p tsconfig.build.json --emitDeclarationOnly --composite false --declaration --outDir dist",
    "dev": "tsup src/index.ts --external @multi-game-engines/* --format esm --watch --dts",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.storybook.json --noEmit",
    "storybook": "storybook dev -p 6008",
    "build-storybook": "storybook build"
  },
  "license": "MIT",
  "sideEffects": [
    "src/components/engine-monitor.ts",
    "src/components/evaluation-graph.ts",
    "src/components/pv-list.ts",
    "src/components/search-log.ts",
    "src/components/score-badge.ts",
    "src/components/engine-stats.ts",
    "dist/*.js"
  ],
  "dependencies": {
    "@multi-game-engines/core": "workspace:*",
    "@multi-game-engines/i18n-common": "workspace:*",
    "@multi-game-engines/ui-chess-elements": "workspace:*",
    "@multi-game-engines/ui-core": "workspace:*",
    "@multi-game-engines/ui-shogi-elements": "workspace:*",
    "lit": "^3.3.3"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "10.4.1",
    "@storybook/addon-docs": "10.4.1",
    "@storybook/addon-links": "10.4.1",
    "@storybook/web-components": "10.4.1",
    "@storybook/web-components-vite": "10.4.1",
    "@swc/core": "^1.15.40",
    "@vueless/storybook-dark-mode": "^10.0.8",
    "jsdom": "^29.1.1",
    "storybook": "10.4.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "author": "hdkz-dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hdkz-dev/multi-game-engines.git",
    "directory": "packages/ui-elements"
  },
  "bugs": {
    "url": "https://github.com/hdkz-dev/multi-game-engines/issues"
  },
  "homepage": "https://github.com/hdkz-dev/multi-game-engines#readme",
  "engines": {
    "node": ">=24.0.0"
  }
}
