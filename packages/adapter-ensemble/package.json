{
  "name": "@multi-game-engines/adapter-ensemble",
  "version": "0.1.0",
  "description": "Multi-engine ensemble (swarm-style) coordination adapter for multi-game-engines ecosystem",
  "type": "module",
  "license": "MIT",
  "author": "hdkz-dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hdkz-dev/multi-game-engines.git",
    "directory": "packages/adapter-ensemble"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "ensemble",
    "multi-agent",
    "swarm",
    "engine",
    "chess",
    "shogi",
    "multi-game-engines"
  ],
  "peerDependencies": {
    "@multi-game-engines/core": "workspace:*"
  },
  "devDependencies": {
    "eslint": "^10.2.0",
    "@multi-game-engines/core": "workspace:*",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "scripts": {
    "build": "tsup src/index.ts --external @multi-game-engines/* --format esm --dts",
    "dev": "tsup src/index.ts --external @multi-game-engines/* --format esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "bugs": {
    "url": "https://github.com/hdkz-dev/multi-game-engines/issues"
  },
  "homepage": "https://github.com/hdkz-dev/multi-game-engines#readme",
  "dependencies": {
    "@multi-game-engines/i18n-common": "workspace:*",
    "@multi-game-engines/i18n-engines": "workspace:*"
  }
}
