{
  "name": "multi-game-engines",
  "private": true,
  "type": "module",
  "description": "A bridge library for various game engines with a plugin-based architecture.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hdkz-dev/multi-game-engines.git"
  },
  "workspaces": [
    "packages/*",
    "examples/*",
    "infrastructure/cdn/cloudflare"
  ],
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "test": "pnpm -r --if-present test",
    "test:e2e": "turbo test:e2e",
    "dev": "turbo dev",
    "dev:dashboard": "npx portless dashboard",
    "dev:vue-dashboard": "npx portless vue-dashboard",
    "dev:registry": "npx portless registry",
    "dev:all": "npx portless",
    "lint": "turbo lint",
    "lint:fix": "turbo lint -- --fix",
    "typecheck": "turbo typecheck",
    "sri:refresh": "node scripts/refresh-engine-sris.mjs",
    "build": "pnpm sri:refresh && turbo build",
    "clean": "find . -type d \\( -name \"dist\" -o -name \".next\" -o -name \".output\" -o -name \".nuxt\" -o -name \"storybook-static\" \\) -not -path \"*/node_modules/*\" -exec rm -rf {} +",
    "clean:deps": "rm -rf node_modules **/node_modules pnpm-lock.yaml",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "mcp:mask": "node scripts/sync-mcp-tokens.js mask",
    "mcp:fill": "node scripts/sync-mcp-tokens.js fill",
    "doc-sync": "node scripts/doc-sync.js",
    "prepare": "husky",
    "release": "pnpm build && changeset publish",
    "ai:check": "pnpm sri:refresh && pnpm lint && pnpm typecheck && pnpm build && pnpm test && pnpm test:e2e",
    "ai:release": "changeset",
    "npm:setup-oidc": "node scripts/setup-trusted-publishers.mjs",
    "docs": "typedoc",
    "docs:check": "typedoc --treatWarningsAsErrors"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowAny": [
        "eslint"
      ]
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "esbuild",
      "sharp",
      "stockfish",
      "unrs-resolver",
      "workerd"
    ],
    "overrides": {
      "@rushstack/ts-command-line": "5.2.0",
      "@microsoft/api-extractor": "7.56.3",
      "brace-expansion": "5.0.5",
      "flatted": "3.4.2",
      "picomatch": "4.0.4",
      "postcss": ">=8.5.10",
      "@vue/runtime-core": "3.5.33",
      "@vue/runtime-dom": "3.5.33",
      "@vue/reactivity": "3.5.33",
      "@vue/compiler-core": "3.5.33",
      "@vue/compiler-dom": "3.5.33",
      "@vue/shared": "3.5.33"
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@vitest/eslint-plugin": "^1.6.16",
    "eslint": "^10.2.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-lit": "^2.2.1",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-storybook": "^10.3.5",
    "eslint-plugin-tsdoc": "^0.5.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-vitest": "^0.5.4",
    "eslint-plugin-wc": "^3.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "portless": "^0.10.3",
    "prettier": "^3.8.3",
    "turbo": "^2.9.6",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix --no-warn-ignored"
    ],
    "*.{json,md,html}": [
      "prettier --write"
    ]
  }
}
